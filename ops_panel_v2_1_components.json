{
  "version": "v2.1",
  "schema": "discord-components-v2",
  "routing": {
    "buttons": {
      "ops.quota.all": "全部模型额度",
      "ops.codex.history": "Codex历史会话",
      "ops.codex.refresh": "刷新Codex缓存",
      "ops.usage.channel_model": "频道/帖子模型",
      "ops.health.snapshot": "本机健康状态",
      "ops.model.switch.commit": "执行模型切换",
      "ops.model.switch.bulk.prepare": "批量切换准备",
      "ops.model.switch.bulk.commit": "批量切换确认",
      "ops.danger.restart.request": "重启网关",
      "ops.danger.channel_delete.request": "频道预览/删除"
    },
    "selects": {
      "ops.quota.provider": [
        "quota_openai",
        "quota_anthropic",
        "quota_google",
        "quota_groq",
        "quota_deepseek"
      ],
      "ops.sessions.active.channel": "channel_select",
      "ops.model.switch.channel": "channel_select",
      "ops.model.switch.model": [
        "codex5.2-main",
        "codex5.2-backup",
        "miaomiao",
        "Kimi for Coding"
      ],
      "ops.model.switch.scope": [
        "current_session",
        "channel_default",
        "channel_active_bulk"
      ]
    },
    "actions": {
      "ops.model.switch.prepare": "模型切换参数预检",
      "ops.model.switch.commit": "模型切换执行",
      "ops.model.switch.bulk.prepare": "批量切换准备（双确认）",
      "ops.model.switch.bulk.commit": "批量切换提交（双确认）"
    }
  },
  "panel_send_payload": {
    "action": "send",
    "channel": "discord",
    "target": "channel:REPLACE_CHANNEL_ID",
    "message": "🛠️ 运维面板（V2.1）",
    "components": {
      "reusable": true,
      "text": "请选择操作（稳定 action key 已启用）",
      "container": {
        "accentColor": "#5865F2"
      },
      "blocks": [
        {
          "type": "section",
          "text": "**快捷操作**"
        },
        {
          "type": "actions",
          "buttons": [
            {
              "label": "全部模型额度",
              "style": "primary",
              "actionKey": "ops.quota.all"
            },
            {
              "label": "Codex历史会话",
              "style": "secondary",
              "actionKey": "ops.codex.history"
            },
            {
              "label": "刷新Codex缓存",
              "style": "secondary",
              "actionKey": "ops.codex.refresh"
            },
            {
              "label": "频道/帖子模型",
              "style": "secondary",
              "actionKey": "ops.usage.channel_model"
            },
            {
              "label": "本机健康状态",
              "style": "success",
              "actionKey": "ops.health.snapshot"
            }
          ]
        },
        {
          "type": "section",
          "text": "**按平台查看单项额度**"
        },
        {
          "type": "actions",
          "select": {
            "type": "string",
            "placeholder": "选择平台",
            "minValues": 1,
            "maxValues": 1,
            "actionKey": "ops.quota.provider",
            "options": [
              {
                "label": "OpenAI",
                "value": "quota_openai"
              },
              {
                "label": "Anthropic",
                "value": "quota_anthropic"
              },
              {
                "label": "Google",
                "value": "quota_google"
              },
              {
                "label": "Groq",
                "value": "quota_groq"
              },
              {
                "label": "DeepSeek",
                "value": "quota_deepseek"
              }
            ]
          }
        },
        {
          "type": "section",
          "text": "**按频道查看活跃会话**"
        },
        {
          "type": "actions",
          "select": {
            "type": "channel",
            "placeholder": "选择频道",
            "minValues": 1,
            "maxValues": 1,
            "actionKey": "ops.sessions.active.channel"
          }
        },
        {
          "type": "section",
          "text": "**频道模型切换（V2.1）**"
        },
        {
          "type": "actions",
          "select": {
            "type": "channel",
            "placeholder": "模型切换目标频道",
            "minValues": 1,
            "maxValues": 1,
            "actionKey": "ops.model.switch.channel"
          }
        },
        {
          "type": "actions",
          "select": {
            "type": "string",
            "placeholder": "选择目标模型",
            "minValues": 1,
            "maxValues": 1,
            "actionKey": "ops.model.switch.model",
            "options": [
              {
                "label": "codex5.2-main",
                "value": "codex5.2-main"
              },
              {
                "label": "codex5.2-backup",
                "value": "codex5.2-backup"
              },
              {
                "label": "miaomiao",
                "value": "miaomiao"
              },
              {
                "label": "Kimi for Coding",
                "value": "Kimi for Coding"
              }
            ]
          }
        },
        {
          "type": "actions",
          "select": {
            "type": "string",
            "placeholder": "选择作用域",
            "minValues": 1,
            "maxValues": 1,
            "actionKey": "ops.model.switch.scope",
            "options": [
              {
                "label": "当前会话（current_session）",
                "value": "current_session"
              },
              {
                "label": "频道默认（channel_default）",
                "value": "channel_default"
              },
              {
                "label": "频道活跃批量（channel_active_bulk）",
                "value": "channel_active_bulk"
              }
            ]
          }
        },
        {
          "type": "actions",
          "buttons": [
            {
              "label": "执行模型切换",
              "style": "primary",
              "actionKey": "ops.model.switch.commit"
            },
            {
              "label": "批量切换准备",
              "style": "danger",
              "actionKey": "ops.model.switch.bulk.prepare"
            },
            {
              "label": "批量切换确认",
              "style": "danger",
              "actionKey": "ops.model.switch.bulk.commit"
            }
          ]
        },
        {
          "type": "section",
          "text": "**危险操作（双确认+TTL+操作者绑定）**"
        },
        {
          "type": "actions",
          "buttons": [
            {
              "label": "重启网关",
              "style": "danger",
              "actionKey": "ops.danger.restart.request"
            },
            {
              "label": "频道预览/删除",
              "style": "danger",
              "actionKey": "ops.danger.channel_delete.request"
            }
          ]
        }
      ]
    }
  }
}
