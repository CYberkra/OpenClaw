# =========================
# Star-Office-UI 最小变量模板
# 用法：复制为 .env 后按需填写
# =========================

# ---- Backend（服务端）----
STAR_OFFICE_ENV=development
FLASK_SECRET_KEY=replace_with_a_long_random_secret
ASSET_DRAWER_PASS=replace_with_strong_drawer_password

# 可选 Gemini
GEMINI_API_KEY=
GEMINI_MODEL=nanobanana-pro

# ---- 本地状态脚本（set_state.py）----
# 可选：指定 state.json 绝对路径
STAR_OFFICE_STATE_FILE=

# ---- 访客 Agent 推送（office-agent-push.py 语义）----
# 这三个值是“接入办公室”必填关键项
JOIN_KEY=ocj_example_team_01
AGENT_NAME=my-agent
OFFICE_URL=http://127.0.0.1:19000

# 可选：push 脚本环境变量
OFFICE_LOCAL_STATE_FILE=
OFFICE_LOCAL_STATUS_URL=http://127.0.0.1:19000/status
OFFICE_LOCAL_STATUS_TOKEN=
OFFICE_STALE_STATE_TTL=600
OFFICE_VERBOSE=0
